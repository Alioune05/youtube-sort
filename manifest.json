{
  "manifest_version": 3,
  "name": "YouTube Tab Sorter",
  "version": "1.0.0",
  "description": "Sort your YouTube tabs by video duration",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["*://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sort YouTube Tabs"
  }
}
